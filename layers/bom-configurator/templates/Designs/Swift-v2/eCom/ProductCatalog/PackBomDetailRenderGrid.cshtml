@inherits ViewModelTemplate<ProductViewModel>
@using Dynamicweb.Rendering
@using Dynamicweb.Ecommerce.ProductCatalog

@*
    PackBomDetailRenderGrid — bom-configurator pack (PK3-01 / PK3-02).

    Pack-owned product-detail render path. The eCom_ProductCatalog app on the
    "Kit Configurator" page (page A) points its ProductTemplate at THIS file. It
    stashes the resolved ProductViewModel into Context.Items["ProductDetails"] and
    renders the pack-owned "Kit Configurator Detail" grid (page B, navigationTag
    PackBomDetail), which carries the stock Swift-v2_ProductBom + Swift-v2_ProductAddToCart
    paragraphs. This delivers the BOM configurator surface WITHOUT editing base
    content (the base Shop PDP stays untouched — Pack #1 Q6 precedent).

    Pack constraints honored:
    - NEW template path only (eCom/ProductCatalog/PackBomDetailRenderGrid.cshtml is
      absent from the stock Swift 2.3 tree) — overlaying a stock file would delete
      the STOCK file at pack teardown.
    - Includes no partials and pack-prefixes every local (packBomDetailPage)
      — the 08-03 Razor inlining-collision lesson.
*@
@{
    if (Dynamicweb.Context.Current?.Items.Contains("ProductDetails") ?? false)
    {
        Dynamicweb.Context.Current.Items["ProductDetails"] = Model;
    }
    else
    {
        Dynamicweb.Context.Current?.Items.Add("ProductDetails", Model);
    }
    var packBomDetailPage = GetPageIdByNavigationTag("PackBomDetail");
}

@RenderGrid(packBomDetailPage)
