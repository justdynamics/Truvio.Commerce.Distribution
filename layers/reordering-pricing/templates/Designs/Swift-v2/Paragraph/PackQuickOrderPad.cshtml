@inherits Dynamicweb.Rendering.ViewModelTemplate<Dynamicweb.Frontend.ParagraphViewModel>
@using Dynamicweb

@*
    PackQuickOrderPad — quick-order pad (reordering-pricing pack, CAND-01).

    - SKU + quantity grid with add-row support and a paste target that accepts
      Excel (tab-separated) and CSV (comma/semicolon) input. Parsing stays
      CLIENT-side: the DW cart engine consumes only the numbered form fields
      (V5 — no custom server parsing).
    - SKU validation rides the same index feed Express Buy uses (feed=true + q
      GET against this page; the paragraph carries the eCom_ProductCatalog
      module with ExpressBuySearchResponse.cshtml as its list template).
      Unknown SKUs are flagged in-grid and excluded from submit. Resolved rows
      show the user-scoped price from the feed. NOTE: this baseline carries no
      assortments; validation degrades gracefully to "product exists + price
      resolves" (see the pack README).
    - One-click cart fill: a single cartcmd=addmulti POST with per-line
      numbered fields ProductLoopCounter{n}/ProductId{n}/VariantId{n}/Quantity{n}
      (the stock Express Buy POST shape). Lines land in the DEFAULT cart.
    - Tier schedule (Q6): illustrative static table driven by this pack's own
      EcomPrices tier rows; engine-side schedules are fed by the pack provider's
      FindQuantityPrices override.
*@

@{
    var cartSummaryPageId = Dynamicweb.Content.Services.Pages.GetPageByNavigationTag(Pageview.Area.ID, "CartSummary")?.ID ?? null;
    string padTitle = Model.Item.GetString("Title");
    padTitle = string.IsNullOrWhiteSpace(padTitle) ? Translate("Quick Order") : padTitle;
    string padIntro = Model.Item.GetString("Intro");
    string iconPath = "/Files/Images/Icons/";
}

<div class="grid item_@Model.Item.SystemName.ToLower()">

    <section class="g-col-12 g-col-lg-8 d-flex flex-column align-content-stretch position-relative">
        <header class="pb-3">
            <h1 class="h3">@padTitle</h1>
            @if (!string.IsNullOrWhiteSpace(padIntro))
            {
                <p class="mb-0">@padIntro</p>
            }
        </header>

        <div class="mb-3">
            <label for="QuickOrderPaste_@Model.ID" class="form-label">@Translate("Paste from Excel or CSV (one line per product: SKU, quantity)")</label>
            <textarea id="QuickOrderPaste_@Model.ID" class="form-control" rows="3" placeholder="RPP-TIER-01&#9;5&#10;RPP-CTR-01&#9;1"></textarea>
        </div>

        <table class="table align-middle" id="QuickOrderTable_@Model.ID">
            <thead>
                <tr>
                    <th scope="col">@Translate("SKU")</th>
                    <th scope="col" style="width:8rem;">@Translate("Quantity")</th>
                    <th scope="col">@Translate("Status")</th>
                    <th scope="col" class="text-end">@Translate("Price")</th>
                    <th scope="col" style="width:3rem;"></th>
                </tr>
            </thead>
            <tbody id="QuickOrderRows_@Model.ID"></tbody>
        </table>

        <div class="d-flex gap-2 pb-3">
            <button type="button" class="btn btn-secondary" data-dw-button="secondary" id="QuickOrderAddRow_@Model.ID">@Translate("Add row")</button>
        </div>

        <form action="/Default.aspx" method="post" id="QuickOrderAddForm_@Model.ID" data-layout-template="Swift-v2_CartSummary.cshtml" data-response-target-element="CartSummaryContainer">
            <input type="hidden" name="ID" value="@Model.PageID">
            <input type="hidden" name="redirect" value="false">
            <input type="hidden" name="cartcmd" value="addmulti">
            <div id="QuickOrderLineFields_@Model.ID"></div>
            <button type="submit" class="btn btn-primary" data-dw-button="primary" id="QuickOrderSubmit_@Model.ID">
                <div class="d-flex gap-2 align-items-center lh-base">
                    <span>@Translate("Add all to cart")</span>
                    <span class="icon-2">
                        @ReadFile(iconPath + "cart-shopping.svg")
                    </span>
                </div>
            </button>
        </form>

        <section class="pt-4">
            <h2 class="h5">@Translate("Volume pricing")</h2>
            <p class="fs-7 mb-2">@Translate("Example volume schedule for") Reordering Tier Product (RPP-TIER-01) — @Translate("unit price per quantity tier"):</p>
            <table class="table table-sm w-auto">
                <thead>
                    <tr>
                        <th scope="col">@Translate("Quantity")</th>
                        <th scope="col" class="text-end">@Translate("Unit price")</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>1 &ndash; 4</td><td class="text-end">4,995.00 EUR</td></tr>
                    <tr><td>5 &ndash; 9</td><td class="text-end">4,500.00 EUR</td></tr>
                    <tr><td>10 &ndash; 24</td><td class="text-end">4,200.00 EUR</td></tr>
                    <tr><td>25+</td><td class="text-end">3,900.00 EUR</td></tr>
                </tbody>
            </table>
            <p class="fs-8 text-muted mb-0">@Translate("This schedule reflects the pack's own EcomPrices tier rows (PACK-RPP-0001..0003). Tier prices are enforced at cart time by the pack's price provider; engine-side tier schedules are fed by its quantity-price surface.")</p>
        </section>
    </section>

    <aside class="g-col-12 g-col-lg-4" data-dw-colorscheme="@Model.ColorScheme?.Id">
        <div class="h-100">
            @if (!Pageview.IsVisualEditorMode)
            {
                <div id="CartSummaryContainer"></div>

                if (cartSummaryPageId != null)
                {
                    <script type="module">
                        document.addEventListener('updated.swift.cart', (event) => {
                            let orderContext = event?.detail?.formData?.get("OrderContext");
                            swift.PageUpdater.UpdateFromUrl(event, '/Default.aspx?ID=@(cartSummaryPageId)&RequestPageID=@(Pageview.Page.ID)&OrderContext=' + orderContext + '', 'Swift-v2_CartSummary.cshtml', document.querySelector('#CartSummaryContainer'));
                        });
                    </script>
                }
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <span>@Translate("Cart Summary")</span>
                </div>
            }
        </div>
    </aside>

</div>

<script type="module">
    const padId = '@Model.ID';
    const pageId = '@Model.PageID';
    const rowsBody = document.querySelector('#QuickOrderRows_' + padId);
    const pasteBox = document.querySelector('#QuickOrderPaste_' + padId);
    const addRowBtn = document.querySelector('#QuickOrderAddRow_' + padId);
    const addForm = document.querySelector('#QuickOrderAddForm_' + padId);
    const lineFields = document.querySelector('#QuickOrderLineFields_' + padId);

    function createRow(sku, qty) {
        const tr = document.createElement('tr');
        tr.className = 'js-quick-order-row';
        tr.dataset.productId = '';
        tr.dataset.variantId = '';
        tr.dataset.valid = 'false';
        tr.innerHTML =
            '<td><input type="text" class="form-control js-qo-sku" maxlength="255" value=""></td>' +
            '<td><input type="number" class="form-control js-qo-qty" min="1" step="1" value="1"></td>' +
            '<td class="js-qo-status fs-7"></td>' +
            '<td class="js-qo-price text-end fs-7"></td>' +
            '<td><button type="button" class="btn btn-sm btn-link js-qo-remove" aria-label="@Translate("Remove")">&times;</button></td>';
        tr.querySelector('.js-qo-sku').value = sku || '';
        const qtyNum = parseInt(qty, 10);
        tr.querySelector('.js-qo-qty').value = (isNaN(qtyNum) || qtyNum < 1) ? 1 : qtyNum;
        tr.querySelector('.js-qo-remove').addEventListener('click', () => tr.remove());
        tr.querySelector('.js-qo-sku').addEventListener('change', () => validateRow(tr));
        rowsBody.appendChild(tr);
        if (sku) { validateRow(tr); }
        return tr;
    }

    // SKU resolution via the same index feed Express Buy uses (feed=true + q GET
    // against this page). The response is the ExpressBuySearchResponse markup:
    // one <article> per hit carrying .productId / .productVariantId hidden inputs,
    // a .productNumber link, and a user-scoped .productPrice.
    async function validateRow(tr) {
        const sku = tr.querySelector('.js-qo-sku').value.trim();
        const statusCell = tr.querySelector('.js-qo-status');
        const priceCell = tr.querySelector('.js-qo-price');
        tr.dataset.valid = 'false';
        tr.dataset.productId = '';
        tr.dataset.variantId = '';
        priceCell.textContent = '';
        if (!sku) { statusCell.textContent = ''; return; }
        statusCell.textContent = '@Translate("Checking")…';
        // WR-05 (Phase 7 review): request-token guard against out-of-order async
        // responses. Two rapid edits create two in-flight lookups with no ordering
        // guarantee; if the FIRST (stale) response arrives LAST it would overwrite
        // the row state with the productId of the PREVIOUS sku while the input
        // shows the new one — submit would then POST the wrong product. The sku
        // captured at request start ('requested') is the token: any response
        // arriving after the input changed (or the row left the DOM) is discarded.
        const requested = sku;
        const isStale = () => !tr.isConnected || tr.querySelector('.js-qo-sku').value.trim() !== requested;
        try {
            const url = '/Default.aspx?ID=' + encodeURIComponent(pageId)
                + '&feed=true&redirect=false&isVariant=true,false&q=' + encodeURIComponent(sku);
            const resp = await fetch(url, { credentials: 'same-origin' });
            const html = await resp.text();
            if (isStale()) { return; }
            const doc = new DOMParser().parseFromString(html, 'text/html');
            let match = null;
            for (const article of doc.querySelectorAll('article')) {
                const numberEl = article.querySelector('.productNumber');
                const idEl = article.querySelector('.productId');
                if (!numberEl || !idEl) { continue; }
                const number = numberEl.textContent.trim();
                if (number.toLowerCase() === sku.toLowerCase()) { match = article; break; }
            }
            if (match) {
                tr.dataset.productId = match.querySelector('.productId').value;
                tr.dataset.variantId = match.querySelector('.productVariantId')?.value || '';
                tr.dataset.valid = 'true';
                statusCell.textContent = '@Translate("OK")';
                statusCell.classList.remove('text-danger');
                statusCell.classList.add('text-success');
                priceCell.textContent = match.querySelector('.productPrice')?.textContent?.trim() || '';
            } else {
                statusCell.textContent = '@Translate("Unknown SKU — excluded from cart")';
                statusCell.classList.remove('text-success');
                statusCell.classList.add('text-danger');
            }
        } catch (err) {
            if (isStale()) { return; }  // WR-05: a stale FAILED lookup must not clobber the newer row state either
            statusCell.textContent = '@Translate("Lookup failed — try again")';
            statusCell.classList.remove('text-success');
            statusCell.classList.add('text-danger');
        }
    }

    // Paste-from-Excel/CSV: rows split on newlines; cells split on TAB first
    // (Excel paste is tab-separated), falling back to comma/semicolon.
    function parsePaste(text) {
        const lines = text.split(/\r?\n/);
        const entries = [];
        for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed) { continue; }
            let cells;
            if (trimmed.indexOf('\t') >= 0) {
                cells = trimmed.split('\t');
            } else {
                cells = trimmed.split(/[;,]/);
            }
            const sku = (cells[0] || '').trim();
            const qty = (cells[1] || '1').trim();
            if (sku) { entries.push({ sku: sku, qty: qty }); }
        }
        return entries;
    }

    pasteBox.addEventListener('paste', (e) => {
        const text = (e.clipboardData || window.clipboardData).getData('text');
        if (!text) { return; }
        e.preventDefault();
        for (const entry of parsePaste(text)) {
            createRow(entry.sku, entry.qty);
        }
        pasteBox.value = '';
    });

    addRowBtn.addEventListener('click', () => createRow('', 1));

    // One-click cart fill: emit the numbered addmulti fields for VALIDATED rows
    // only, then submit through the Swift PageUpdater (async, refreshes the cart
    // summary container via data-layout-template / data-response-target-element).
    addForm.addEventListener('submit', (e) => {
        e.preventDefault();
        lineFields.innerHTML = '';
        let n = 0;
        for (const tr of rowsBody.querySelectorAll('.js-quick-order-row')) {
            if (tr.dataset.valid !== 'true' || !tr.dataset.productId) { continue; }
            const qty = parseInt(tr.querySelector('.js-qo-qty').value, 10);
            if (isNaN(qty) || qty < 1) { continue; }
            n += 1;
            const block = [
                ['ProductLoopCounter' + n, String(n)],
                ['ProductId' + n, tr.dataset.productId],
                ['VariantId' + n, tr.dataset.variantId],
                ['Quantity' + n, String(qty)]
            ];
            for (const pair of block) {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = pair[0];
                input.value = pair[1];
                lineFields.appendChild(input);
            }
        }
        if (n === 0) { return; }
        swift.PageUpdater.Update(addForm);
    });

    // Start with one empty row so the grid is immediately usable.
    createRow('', 1);
</script>
