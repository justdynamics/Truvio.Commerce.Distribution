@inherits ViewModelTemplate<OrderListViewModel>
@using Dynamicweb.Frontend
@using Dynamicweb.Rendering
@using Dynamicweb.Ecommerce.Frontend
@using Dynamicweb.Ecommerce.Orders
@using Microsoft.Extensions.DependencyInjection

@* Pack: feature-subscription-orders. Subscriptions list for the eCom_CustomerExperienceCenter app with
   OrderType=Recurringorder. Data access goes through DI-resolved services ONLY (the static
   RecurringOrder accessors are [Obsolete]; direct database-layer calls are forbidden - Check 7). *@

@{
    string baseUrl = SearchEngineFriendlyURLs.GetFriendlyUrl($"default.aspx?ID={Pageview.Page.ID}");

    @* 08-03 live fix: the resolver type is Dynamicweb.Extensibility.Dependencies.DependencyResolver
       on DW 10.26.9 (reflection-verified in Dynamicweb.Core.dll; the .Dependencies segment was
       missing and the template failed compilation into a source-dump render). Current is an
       IServiceProvider, so the M.E.DI GetRequiredService<T> extension applies. *@
    var recurringService = Dynamicweb.Extensibility.Dependencies.DependencyResolver.Current
        .GetRequiredService<RecurringOrderService>();

    @* End-subscription action: POST-only (read from Form, never QueryString) with the MANDATORY
       ownership guard - Pageview.User must be signed in AND the recurring row's UserId must equal
       the signed-in user's ID before EndRecurring runs (ASVS V4; the legacy delete handler lacks
       this check and is deliberately NOT copied). Residual CSRF risk documented in the pack README. *@
    var cancelId = Dynamicweb.Context.Current?.Request.Form["PackEndSubscriptionId"];
    if (!string.IsNullOrEmpty(cancelId) && Pageview.User != null)
    {
        var r = recurringService.GetById(Dynamicweb.Core.Converter.ToInt32(cancelId));
        if (r != null && r.UserId == Pageview.User.ID)
        {
            recurringService.EndRecurring(r.ID);
        }
    }
}

<header class="hstack gap-3 mb-4">
    <h1 class="h4 mb-0">@(Pageview.Page.GetDisplayName())</h1>
</header>

<div class="card overflow-hidden">
    <div class="table-responsive">
        <table class="table table-md table-hover mb-0 align-middle fs-7" style="--bs-table-color: var(--bs-body-color);">
            <thead style="--bs-table-bg: rgba(var(--bs-body-color-rgb), .0275); --bs-table-color: rgba(var(--bs-body-color-rgb), 0.5);">
                <tr>
                    <th>@Translate("Subscription")</th>
                    <th>@Translate("Order")</th>
                    <th>@Translate("Created")</th>
                    <th>@Translate("Interval")</th>
                    <th>@Translate("Starts")</th>
                    <th>@Translate("Next delivery")</th>
                    <th>@Translate("Total")</th>
                    <th>@Translate("Actions")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders)
                {
                    @* Primary resolution: RecurringOrderId on the list view model (A2). Fallback
                       (verified public) if it resolves nothing: GetByBaseOrderId(order.Id). *@
                    var recurring = recurringService.GetById(order.RecurringOrderId ?? 0)
                        ?? recurringService.GetByBaseOrderId(order.Id);
                    bool ended = recurring?.EndDate != null && recurring.EndDate <= System.DateTime.Now;

                    <tr class="position-relative" data-pack-subscription-id="@(recurring?.ID)">
                        <td>@(recurring?.ID)</td>
                        <td>
                            <a class="position-relative z-2 text-decoration-none text-decoration-underline-hover" href="@(baseUrl)?OrderId=@(order.Id)">@(order.Id)</a>
                        </td>
                        <td>
                            <div class="vstack">
                                @(order.CreatedAt.ToShortDateString())
                                <span class="fs-8 text-muted">@(order.CreatedAt.ToShortTimeString())</span>
                            </div>
                        </td>
                        <td>@(recurring?.Interval) @(recurring?.IntervalUnit)</td>
                        <td>@(recurring?.StartDate)</td>
                        <td>@(recurring?.NextDelivery)</td>
                        <td>
                            <div class="text-price">@(order.Price.PriceFormatted)</div>
                        </td>
                        <td>
                            @if (recurring != null && !ended)
                            {
                                <form method="post" action="@(baseUrl)" class="d-inline position-relative z-2"
                                      onsubmit="return confirm('@Translate("End this subscription?")');">
                                    <input type="hidden" name="PackEndSubscriptionId" value="@(recurring.ID)" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary text-body" data-dw-button="outline-secondary">
                                        @Translate("End subscription")
                                    </button>
                                </form>
                            }
                            else if (ended)
                            {
                                <span class="badge lh-sm bg-secondary">@Translate("Ended")</span>
                            }
                        </td>
                    </tr>
                }

                @if (Model.Orders.Count() < 1)
                {
                    <tr class="position-relative">
                        <td colspan="8">
                            <div class="d-grid py-4">
                                <span class="m-auto text-center">
                                    <div class="mt-3">@Translate("No subscriptions yet")</div>
                                </span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.PageCount > 1)
{
    <div class="hstack justify-content-between mt-3">
        <div class="text-muted fs-7">
            @Translate("Showing page") @(Model.CurrentPage) @Translate("of") @(Model.PageCount)
        </div>
    </div>
}
