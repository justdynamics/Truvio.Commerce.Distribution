@inherits Dynamicweb.Rendering.RazorTemplateBase<Dynamicweb.Rendering.RazorTemplateModel<Dynamicweb.Rendering.Template>>
@using Dynamicweb

@* Pack: subscription-orders. Z-copy of the stock PaymentUser.cshtml (gtag block dropped) with
   shipping selection added (the 3-step flow collapses delivery+payment onto step 1) and the
   recurring panel inserted inside the RecurringSupport guard.

   CRITICAL (Pitfall 4): the EcomRecurringOrderCreate checkbox below is the ONLY element STATICALLY
   carrying that field name. NEVER add a static hidden companion input for the unchecked state - a
   present-but-empty EcomRecurringOrderCreate value actively DELETES the cart's recurring template,
   so a static companion would tear down the draft on EVERY non-subscribing checkout.

   CR-01 (Phase 8 review) - deliberate-cancel path: the field-absent state leaves an EXISTING draft
   untouched, so a user who checked the box, auto-posted (shipping/payment onchange submitForm()),
   then UNCHECKED it would still complete as a subscription. packSyncRecurringCancel() below emits
   the engine's designed cancel signal (ONE JS-created hidden empty-value field) ONLY when a draft
   exists (data-was-checked="true", i.e. Ecom:Order.Recurring.Enabled at render time) AND the user
   explicitly unchecks - never statically, so accidental-empty stays structurally impossible. *@

<div class="grid gap-0 h-100" id="PackSubscribeCheckout">
	<div class="cart g-col-12 g-col-lg-8 p-3 p-lg-4 pe-xl-5 ps-xl-6 ps-xxl-8 order-last order-lg-first" data-dw-colorscheme="@Pageview.CurrentParagraph?.ColorSchemeId">
		<form name="ordersubmit" id="ordersubmit" method="post" autocomplete="off" style="max-width: 65rem; margin-left: auto;">

			@Include("Helpers/Logo.cshtml")

			@Include("Helpers/StepsBreadcrumbs.cshtml")

			@Include("Helpers/Errors.cshtml")

			@Include("Helpers/StepSummary.cshtml")

			@* Pack Z-copy helper (NOT the stock ShippingMethods.cshtml): this is the only
			   Swift document combining the shipping + payment helpers, and both stock helpers
			   declare a local `methodSelected` — DW inlines @Include'd helpers into ONE
			   generated class, so the combined document failed C# compilation and DW rendered
			   a source dump instead of the checkout (08-03 live finding). The pack copy
			   prefixes its locals (packShipping*) and carries its own heading. *@
			@Include("Helpers/PackShippingMethods.cshtml")

			<div class="mt-4">

				<h3 class="fs-6 fw-normal mb-0">@Translate("Select payment")</h3>
				<p class="fs-8 mb-3">@Translate("All transactions are encrypted")</p>

				@Include("Helpers/PaymentMethods.cshtml")

			</div>

			@if (GetString("Ecom:Order.PaymentMethod.RecurringSupport") == "true")
			{
				<div class="pack-subscription-panel mt-4">
					<h3 class="fs-6 fw-normal mb-3">@Translate("Subscription")</h3>
					<div class="form-check mb-3">
						<input type="checkbox" class="form-check-input" name="EcomRecurringOrderCreate" id="EcomRecurringOrderCreate" value="True"
							   data-was-checked="@(GetString("Ecom:Order.Recurring.Enabled") == "true" ? "true" : "false")"
							   @(GetString("Ecom:Order.Recurring.Enabled") == "true" ? "checked" : "")
							   onchange="packSyncRecurringCancel(this)" />
						<label class="form-check-label" for="EcomRecurringOrderCreate">@Translate("Make this a recurring order")</label>
					</div>
					<div class="hstack gap-2 mb-3">
						<label class="form-label mb-0" for="EcomOrderRecurringInterval">@Translate("Deliver every")</label>
						<input type="number" class="form-control" style="max-width: 6rem;" name="EcomOrderRecurringInterval" id="EcomOrderRecurringInterval" min="1"
							   value="@(GetString("Ecom:Order.Recurring.Interval") ?? "1")" />
						<select class="form-select" style="max-width: 10rem;" name="EcomOrderRecurringIntervalUnit">
							<option value="0">@Translate("Days")</option>
							<option value="1">@Translate("Weeks")</option>
							<option value="2">@Translate("Months")</option>
						</select>
					</div>
					@GetString("Ecom:Order.Recurring.StartDate")
					@GetString("Ecom:Order.Recurring.EndDate")
				</div>
			}

			@Include("Helpers/OrderReference.cshtml")

			@Include("Helpers/OrderComment.cshtml")

			@Include("Helpers/StepsNavigation.cshtml")

			<input type="hidden" id="CurrentStep">
		</form>
	</div>

	@Include("Helpers/SummarySidebar.cshtml")

</div>

<script>
	function submitForm() {
		document.querySelector("#CurrentStep").name = "@GetString("CartV2.CurrentStepButtonName")";
		swift.PageUpdater.Update(document.querySelector("#ordersubmit"));
	}

	function packSyncRecurringCancel(cb) {
		// CR-01 (Phase 8 review). Engine contract (Pitfall 4 table in the pack README):
		// present-but-empty EcomRecurringOrderCreate DELETES the cart's recurring draft.
		// Emit that cancel signal ONLY when a draft exists (was-checked at render time)
		// and the user explicitly unchecks - never statically, never on a fresh checkbox.
		let h = document.getElementById('PackRecurringCancel');
		if (!cb.checked && cb.dataset.wasChecked === 'true') {
			if (!h) {
				h = document.createElement('input');
				h.type = 'hidden';
				h.id = 'PackRecurringCancel';
				h.name = 'EcomRecurringOrderCreate';
				h.value = '';
				cb.form.appendChild(h);
			}
		} else if (h) {
			h.remove();
		}
	}
</script>
